# Comportamiento por defecto para archivos de texto
* text=auto

# Patrones específicos para forzar finales de línea LF (Unix)
*.gradle text eol=lf
*.properties text eol=lf
*.toml text eol=lf
*.mcmeta text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Patrones específicos para forzar finales de línea CRLF (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Archivos binarios (no son texto)
*.png binary
*.jar binary
*.class binary
*.dll binary
*.exe binary